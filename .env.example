# Postgres (Neon) — connection string com pooler
DATABASE_URL=

# Senha do painel admin
ADMIN_PASSWORD=

# Segredo do Better Auth (sessões/cookies) — gere com: openssl rand -hex 32
AUTH_SECRET=

# URL base do app para o Better Auth (ex: http://localhost:3000 ou https://seu-app.vercel.app)
BETTER_AUTH_URL=

# Segredo do cron de sync (Vercel Cron)
CRON_SECRET=

# Token da football-data.org (opcional, só para o sync automático)
FOOTBALL_DATA_TOKEN=
